<!DOCTYPE html>
<html>
<head>
  <title>Gift Booking & Delivery</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      margin: 0;
      padding: 0;
      background: #fdfdfd;
    }

    /* Logo gift box */
    .gift-box {
      width: 120px;
      height: 120px;
      background-color: crimson;
      position: relative;
      margin: 40px auto 20px auto;
      border-radius: 12px;
    }
    .gift-box::before {
      content: "";
      position: absolute;
      top: 0;
      left: 55px;
      width: 10px;
      height: 120px;
      background-color: gold;
    }
    .gift-box::after {
      content: "";
      position: absolute;
      top: 55px;
      left: 0;
      width: 120px;
      height: 10px;
      background-color: gold;
    }
    .bow {
      width: 0;
      height: 0;
      border-left: 30px solid transparent;
      border-right: 30px solid transparent;
      border-bottom: 30px solid gold;
      position: absolute;
      top: -30px;
      left: 30px;
    }

    .arc-text {
      font-size: 22px;
      color: brown;
      font-weight: bold;
      margin-bottom: 30px;
    }

    .book-link {
      display: inline-block;
      padding: 12px 24px;
      background: gold;
      color: crimson;
      font-weight: bold;
      text-decoration: none;
      border-radius: 8px;
      margin: 20px 0;
    }

    .gift-section {
      margin: 40px auto;
      max-width: 800px;
    }
    .gift-item {
      margin: 20px 0;
    }
    .gift-item img {
      width: 200px;
      height: 150px;
      background: #eee;
      display: block;
      margin: 0 auto 10px auto;
    }
    .gift-item p {
      margin: 5px 0;
    }
    .gift-item .price {
      font-weight: bold;
      color: green;
    }

    form {
      margin: 40px auto;
      max-width: 400px;
      text-align: left;
    }
    label {
      font-weight: bold;
    }
    textarea {
      width: 100%;
      height: 80px;
      margin: 10px 0;
    }
    input[type="submit"] {
      display: block;
      margin: 10px auto;
      padding: 10px 20px;
      background: crimson;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
    }

    .total {
      margin: 30px auto;
      font-size: 20px;
      font-weight: bold;
      color: navy;
    }
  </style>
</head>
<body>

  <!-- Logo -->
  <div class="gift-box">
    <div class="bow"></div>
  </div>
  <div class="arc-text">Send Gifts and Happiness</div>

  <!-- Booking link -->
  <a href="#gifts" class="book-link">Click here to book your gift</a>

  <!-- Gift options -->
  <div id="gifts" class="gift-section">
    <div class="gift-item">
      <img src="#" alt="Chocolate Bouquet">
      <p>Chocolate Bouquet</p>
      <p class="price">Amount: ₹500</p>
      <p><a href="#">Click here to choose chocolates</a></p>
    </div>
    <div class="gift-item">
      <img src="#" alt="Teddy Toy">
      <p>Teddy Toy</p>
      <p class="price">Amount: ₹800</p>
      <p><a href="#">Click here to add Teddy Toy</a></p>
    </div>
    <div class="gift-item">
      <img src="#" alt="Bedsheet">
      <p>Bedsheet</p>
      <p class="price">Amount: ₹1200</p>
      <p><a href="#">Click here to add Bedsheet</a></p>
    </div>
    <div class="gift-item">
      <img src="#" alt="Blanket">
      <p>Blanket</p>
      <p class="price">Amount: ₹1500</p>
      <p><a href="#">Click here to add Blanket</a></p>
    </div>
  </div>

  <!-- Address form -->
  <form>
    <label>Delivery Address:</label><br>
    <p>write the reciever's address</p>
    <textarea name="address"></textarea><br>
    <input type="submit" value="Submit Address">
  </form>


  <!-- Total -->
  <div class="total">Total Amount: ₹4000</div>

</body>
</html>

